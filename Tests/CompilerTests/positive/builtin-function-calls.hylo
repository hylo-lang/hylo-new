//! stage:run stdlib:minimal


public struct SimpleInt is Deinitializable {

  /// The raw value of this instance.
  internal var value: Builtin.word

  /// Creates an instance with its raw value.
  internal init(_ value: Builtin.word) {
    &self.value = value
  }

  /// Creates an instance equal to `false`.
  public init() {
    &self.value = Builtin.zeroinitializer_word()
  }

  @extern("hylo_successor_int")
  public fun successor() -> Self


  public fun infix== (other: Self) -> Bool {
    Bool.new(value: Builtin.icmp_eq_word(self.value, other.value))
  }

  public fun infix!= (other: Self) -> Bool {
    Bool.new(value: Builtin.icmp_ne_word(self.value, other.value))
  }


  public fun infix< (other: Self) -> Bool {
    Bool.new(value: Builtin.icmp_slt_word(self.value, other.value))
  }

  public fun infix<= (other: Self) -> Bool {
    Bool.new(value: Builtin.icmp_sle_word(self.value, other.value))
  }

  public fun infix> (other: Self) -> Bool {
    Bool.new(value: Builtin.icmp_sgt_word(self.value, other.value))
  }

  public fun infix>= (other: Self) -> Bool {
    Bool.new(value: Builtin.icmp_sge_word(self.value, other.value))
  }

}

fun print_bool(b: Bool) {
  if b {
    print(Int.one())
  } else {
    print(Int.zero())
  }
}

fun print_simple_int(i: SimpleInt) {
  print(Int(from_raw: i.value))
}

public fun main() {
  print_simple_int(SimpleInt())
  print_bool(Bool.makeTrue())
  print_bool(Bool.makeFalse())

  print_bool(SimpleInt().successor() == SimpleInt())
  print_bool(SimpleInt().successor() != SimpleInt())
  print_bool(SimpleInt().successor() < SimpleInt())
  print_bool(SimpleInt().successor() <= SimpleInt())
  print_bool(SimpleInt().successor() > SimpleInt())
  print_bool(SimpleInt().successor() >= SimpleInt())

  print_bool(SimpleInt() == SimpleInt())
  print_bool(SimpleInt() != SimpleInt())
  print_bool(SimpleInt() < SimpleInt())
  print_bool(SimpleInt() <= SimpleInt())
  print_bool(SimpleInt() > SimpleInt())
  print_bool(SimpleInt() >= SimpleInt())

  print_bool(SimpleInt() == SimpleInt().successor())
  print_bool(SimpleInt() != SimpleInt().successor())
  print_bool(SimpleInt() < SimpleInt().successor())
  print_bool(SimpleInt() <= SimpleInt().successor())
  print_bool(SimpleInt() > SimpleInt().successor())
  print_bool(SimpleInt() >= SimpleInt().successor())

}
