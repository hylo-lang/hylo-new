//! stage:lowering

struct Immovable is Deinitializable { public memberwise init }

fun use<T>(x: T) {}

fun main() {
  // If the LHS does not occurs in the RHS, then the latter can be constructed in place.
  var x0: Immovable
  &x0 = .new()

  // If the LHS occurs in the the RHS, the the latter must be stored in a temporary.
  var x1 = 0
  &x1 = x1 + 1

  var x2 = (0xa, 0xb)
  &x2.0 = x2.1 + 1
  use(x2)
}
