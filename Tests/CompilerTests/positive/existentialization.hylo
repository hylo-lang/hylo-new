//! stage:lowering

fun exit<T>() -> Bool { true }

fun loop<T, U>() {
  // Each recursive application requires a new type witness, unless `exit` is inlined and the
  // compiler eliminates dead code. Regardless, `U` can be eliminated with monomorphization.
  if !exit<T>() { loop<{T, T}, U>() }
}

fun nest<T is Movable>(x: sink T) -> {T} {
  (x,)
}

let four: Int = 4

public fun main() {
  // Calls to polymorphic functions are depolymorphized.
  loop<Void, Void>()
  _ = nest(1)

  // Calls to monomorphic functions are copied.
  _ = four == 4
}
