//! stage:lowering

fun exit<T>() -> Bool { true }

fun loop<T, U>() {
  // Each recursive application requires a new type witness, unless `exit` is inlined and the
  // compiler eliminates dead code. Regardless, `U` can be eliminated with monomorphization.
  if !exit<T>() { loop<{T, T}, U>() }
}

public fun main() {
  loop<Void, Void>()
}
