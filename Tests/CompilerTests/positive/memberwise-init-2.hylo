//! stage:typing no-std

struct A {
  public memberwise init
  public let m0 = ()
  public let m1: Void
}

struct B {
  public memberwise init
  public let (m0, _, m1): {Void, Void, Void}
}

struct C {
  public memberwise init
  public let m0: Void
  public static let m1 = ()
}

fun a() -> A { A(m0: (), m1: ()) }

fun b() -> B { B(m0: (), m1: ()) }

fun c() -> C { C(m0: ()) }
