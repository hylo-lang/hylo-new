//! stage:lowering

struct A<U> is Deinitializable {
  public fun f(x: U) {}
  public memberwise init
}

extension <T> A<T> {
  public fun g(x: T) {}
}

trait P { fun h(x: Void) }
given <T> A<T> is P {
  public fun h(x: Void) {}
}

fun use(a: A<Void>) {
  a.f(())
  a.g(())
  a.h(())
}

public fun main() {
}
