//! stage:typing no-std

struct A<T> {
  public var x: T
  public memberwise init
  public static fun make(x: sink T) -> A<T> { .new(x: x) }
}

extension <T> A<T> {
  public fun id() sink -> Self { self }
}

public fun use<T>(x: A<T>) {}

public fun main() {
  let a0: A<_> = .new(x: ())
  let a1: A<_> = .make(())
  let a2: A<_> = .make(()).id()

  use(.new(x: ()))
  use(.make(()).id())
}
