@c_ffi("c_print_int_indirect")
fun print(n: Int) -> Void

struct Point is Deinitializable {

  var x: Int
  var y: Int

  memberwise init

  @c_ffi("c_point_add_indirect")
  fun infix+(other: Point) -> Point

  fun deinit() sink {
    _ = &self.x
    _ = &self.y
  }

}

extension Int {

  @c_ffi("c_add_int_indirect")
  fun infix+(other: Int) -> Int

  @c_ffi("c_int_to_i32_indirect")
  fun toi32() -> Int32

}

public fun main() -> Int32 {
  sink let p = Point(x: 1, y: 2)
  sink let q = Point(x: 3, y: 4)
  sink let r = p + q

  return (r.x + r.y).toi32()
}
