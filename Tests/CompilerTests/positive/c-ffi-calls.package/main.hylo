struct Point is Deinitializable {

  var x: Int
  var y: Int

  memberwise init

  @c_ffi("c_point_add_indirect")
  fun infix+(other: Point) -> Point

  fun deinit() sink {
    _ = &self.x
    _ = &self.y
  }

}

extension Int {

  @c_ffi("c_add_int_indirect")
  fun infix+(other: Int) -> Int

  @c_ffi("c_int_to_i32_indirect")
  fun to_i32() -> Int32

}

@c_ffi("c_byte_set_value_to_3_indirect")
fun set_value_to_3(of_byte_at address: Pointer<Never>)

@c_ffi("c_byte_get_value")
fun get_value(of_byte_at address: Pointer<Never>) -> Int

public fun main() -> Int32 {
  let p = Point(x: 1, y: 2)
  let q = Point(x: 3, y: 4)
  let r = p + q // == Point(4, 6)
  
  let pointer = malloc(1)
  set_value_to_3(of_byte_at: pointer)
  let three = get_value(of_byte_at: pointer)
  
  return (r.x + r.y + three).to_i32() // 4 + 6 + 3 == 13
}
